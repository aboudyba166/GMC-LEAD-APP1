# Local: `npm run dev` → http://localhost:3000  |  EADDRINUSE: use `npm run dev:3001` or free port 3000
# Google Cloud API key with "Google Sheets API" enabled (used server-side; no service account)
# In Google Cloud → APIs & Services → Credentials → Create credentials → API key
# Spreadsheets must be readable with the key: use Share → "Anyone with the link" (Viewer) or public.
GOOGLE_API_KEY=

# Optional: set on Hostinger / production
# NODE_ENV=production
# Hostinger sets PORT automatically — `npm start` uses it (see HOSTINGER.md)
# DATABASE_PATH=/path/on/server/to/leads.db  (persistent disk; default is ./data/leads.db under the app)
